#!name =  iRingo: 🌤 WeatherKit (Rewrite) - iOS 27 Experimental
#!desc = iOS 18+ / experimental iOS 27 compatibility
#!openUrl = http://boxjs.com/#/app/iRingo.WeatherKit
#!author = VirgilClyne[https://github.com/VirgilClyne],WordlessEcho[https://github.com/WordlessEcho],001[https://github.com/001ProMax],silentoy iOS27 experimental patch
#!homepage = https://github.com/silentoy/WeatherKit
#!icon = https://developer.apple.com/assets/elements/icons/weatherkit/weatherkit-128x128.png
#!category =  iRingo
#!date = 2026-06-29 17:00:00

[Rule]
DOMAIN,weather-analytics-events.apple.com,REJECT-DROP
DOMAIN-SUFFIX,tthr.apple.com,REJECT-DROP
DOMAIN,tether.edge.apple,REJECT-DROP
AND,((OR,((IP-ASN,714,no-resolve),(IP-ASN,6185,no-resolve))),(PROTOCOL,QUIC)),REJECT-DROP

[URL Rewrite]
# 🌤 WeatherKit.api.v1.availability.response
^https?:\/\/weatherkit\.apple\.com\/api\/v1\/availability\/ https://weatherkit.nanocat.cloud/api/v1/availability/ header
# 🌤 WeatherKit.api.v2.weather.response
^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/ https://weatherkit.nanocat.cloud/api/v2/weather/ header
# 🌤 WeatherKit.api.v3.weather.response - iOS 27 experimental
^https?:\/\/weatherkit\.apple\.com\/api\/v3\/weather\/ https://weatherkit.nanocat.cloud/api/v3/weather/ header
# 🌤 WeatherKit.api.v2.availability.response - compatibility fallback
^https?:\/\/weatherkit\.apple\.com\/api\/v2\/availability\/ https://weatherkit.nanocat.cloud/api/v2/availability/ header
# 🌤 WeatherKit.api.v3.availability.response - iOS 27 experimental
^https?:\/\/weatherkit\.apple\.com\/api\/v3\/availability\/ https://weatherkit.nanocat.cloud/api/v3/availability/ header

[MITM]
hostname = %APPEND% weatherkit.apple.com
