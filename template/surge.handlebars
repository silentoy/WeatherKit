#!name = {{@package 'displayName'}}
#!desc = iOS 18+ / macOS 15+ / watchOS 11+，包含 iOS 27 WeatherKit v3 兼容\n1.解锁全部天气功能\n2.替换空气质量数据\n3.添加下一小时降水数据\n4.添加天气数据\n5.兼容 /api/v3/availability 与 /api/v3/weather
#!openUrl = {{@package 'openUrl'}}
#!author = {{@package 'contributors'}}
#!homepage = {{@package 'homepage'}}
#!icon = {{@package 'icon'}}
#!category = {{@package 'organizationName'}}
#!date = {{now "yyyy-MM-dd HH:mm:ss"}}
#!version = {{@package 'version'}}
#!arguments = {{{arguments}}}
#!arguments-desc = {{{argumentsDesc}}}

[Rule]
DOMAIN,weather-analytics-events.apple.com,REJECT-DROP
DOMAIN-SUFFIX,tthr.apple.com,REJECT-DROP,extended-matching
DOMAIN,tether.edge.apple,REJECT-DROP,extended-matching
AND,((OR,((IP-ASN,714,no-resolve),(IP-ASN,6185,no-resolve))),(PROTOCOL,QUIC)),REJECT-DROP

[Script]
🌤 WeatherKit.api.v1.availability.response = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v1\/availability\/, requires-body=1, engine=webview, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v{{@package 'version'}}/response.bundle.js, argument={{{scriptParams}}}
🌤 WeatherKit.api.v2.availability.response = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v2\/availability\/, requires-body=1, engine=webview, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v{{@package 'version'}}/response.bundle.js, argument={{{scriptParams}}}
🌤 WeatherKit.api.v3.availability.response = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v3\/availability\/, requires-body=1, engine=webview, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v{{@package 'version'}}/response.bundle.js, argument={{{scriptParams}}}
🌤 WeatherKit.api.v2.weather.response = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v2\/weather\/, requires-body=1, binary-body-mode=1, engine=webview, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v{{@package 'version'}}/response.bundle.js, argument={{{scriptParams}}}
🌤 WeatherKit.api.v3.weather.response = type=http-response, pattern=^https?:\/\/weatherkit\.apple\.com\/api\/v3\/weather\/, requires-body=1, binary-body-mode=1, engine=webview, script-path=https://github.com/NSRingo/WeatherKit/releases/download/v{{@package 'version'}}/response.bundle.js, argument={{{scriptParams}}}

[MITM]
hostname = %APPEND% weatherkit.apple.com
